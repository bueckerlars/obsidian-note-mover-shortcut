{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "importHelpers": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ES2022"],
    "types": ["node", "vitest/globals"]
  },
  "include": ["**/*.ts"]
}
